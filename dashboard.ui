  <property name="styleSheet">
   <string notr="true">
    QMainWindow {
        background-color: #f4f6f9;
    }
    #sidebarFrame {
        background-color: #1a437c;
        border: none;
    }
    QToolButton {
        color: white;
        background: transparent;
        border: none;
        padding: 12px;
        font-size: 16px;
    }
    QToolButton:hover {
        background-color: #245ba3;
        border-radius: 4px;
    }
    #headerFrame {
        background-color: #1f5296;
        border: none;
    }
    #dispatchLabel {
        color: white;
        font-weight: bold;
        font-size: 16px;
        padding-left: 10px;
    }
    #searchBar {
        background-color: white;
        border: 1px solid #ccd4e0;
        border-radius: 4px;
        padding: 4px 8px;
    }
    QTableWidget {
        background-color: white;
        border: 1px solid #e1e6eb;
        gridline-color: #eef2f7;
        border-radius: 6px;
        font-size: 13px;
    }
    QHeaderView::section {
        background-color: #eff3f8;
        color: #55637a;
        padding: 8px;
        font-weight: bold;
        border: none;
        border-bottom: 2px solid #d2d9e1;
    }
